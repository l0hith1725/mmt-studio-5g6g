# SA Tester 5G — Environment Configuration
# This file is read by the systemd service unit.
# Edit and restart: sudo systemctl restart satester

# Web UI binding
SA_TESTER_WEB_HOST=0.0.0.0
SA_TESTER_WEB_PORT=5000

# AMF target (sa_core)
# SA_TESTER_AMF_IP=192.168.1.107
# SA_TESTER_AMF_PORT=38412

# PYTHONPATH (bundled libs)
PYTHONPATH=/opt/satester:/opt/satester/libs:/opt/satester/libs/pycrate
